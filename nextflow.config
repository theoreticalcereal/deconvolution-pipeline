params {
    // Input directory basename for normal runs; compare_psf can infer it from --decon_input_dir.
    cell_name   = ''
    // Optional cell index suffix for raw MATLAB-style input folder naming.
    cell_index  = ''
    // Channel filter, comma/space separated; empty means all discovered channels.
    channels    = ''
    // Timepoint filter, comma/space separated; empty means all discovered timepoints.
    timepoints  = ''
    // Published output directory for workflow products.
    output_dir  = 'output'
    // Skip deskew and run only deconvolution from --decon_input_dir.
    decon_only  = false
    // Run the PSF/deconvolution comparison workflow instead of normal decon output.
    compare_psf = false
    // Directory containing already deskewed TIFFs for decon_only or compare_psf runs.
    decon_input_dir = ''
    // Zero-based TIFF index after channel/timepoint filtering for compare_psf.
    tiff_index  = 0
    // Center XY crop size for compare_psf; <= 0 uses full XY.
    sanity_xy   = 768

    // Deskew voxel size in X/Y, in microns.
    dx          = 0.118
    // Deskew/decon voxel size in Z, in microns.
    dz          = 0.118
    // Deskew shear angle in degrees.
    angle       = 40
    // Deskew flip/orientation flag passed through to deskew code.
    flip        = 1

    // Constant background subtraction applied during PSF generation/handling.
    background  = 0
    // Richardson-Lucy iteration count for normal deconvolution and compare Dec2.
    iter        = 10

    // Fallback numerical aperture used when detection/illumination NA are unset.
    na          = 1.0
    // Detection objective numerical aperture; empty falls back to --na.
    detection_na = ''
    // Illumination objective numerical aperture; empty falls back to --na.
    illumination_na = ''
    // Emission wavelength in microns for PSF generation and CUDA deconvolution.
    wavelength  = 0.520
    // Immersion refractive index for PSF generation.
    ni          = 1.515
    // Specimen/sample refractive index; empty lets the PSF code choose its default.
    ns          = ''
    // Design immersion refractive index for vectorial PSF modeling.
    ni0         = ''
    // Coverslip thickness in microns for the actual optical path.
    tg          = ''
    // Design coverslip thickness in microns for vectorial PSF modeling.
    tg0         = ''
    // Coverslip refractive index for the actual optical path.
    ng          = ''
    // Design coverslip refractive index for vectorial PSF modeling.
    ng0         = ''
    // Design immersion thickness in microns for vectorial PSF modeling.
    ti0         = ''
    // Oversampling factor used when generating the theoretical PSF.
    oversample_factor = 3
    // Theoretical PSF model: vectorial, scalar, or gaussian.
    psf_model   = 'vectorial'
    // Camera pixel size in microns; with magnification this can derive dxy.
    camera_pixel_size = ''
    // Objective/tube magnification; with camera_pixel_size this can derive dxy.
    magnification = ''
    // Final sample pixel size in X/Y, in microns, unless derived from camera settings.
    dxy         = 0.118
    // Number of Z planes in the generated theoretical PSF.
    psf_size_z  = 101
    // Generated theoretical PSF width/height in pixels.
    psf_size_xy = 61

    // MATLAB deconvblind iteration count for blind PSF estimation.
    blind_iters = 10
    // Blind PSF estimation XY tile size; <= 0 auto-sizes conservatively.
    chunk_xy    = 256
    // CUDA deconvolution core XY tile size; <= 0 auto-sizes from available VRAM.
    decon_chunk_xy = 0
    // XY halo per edge before MATLAB deconvblind.
    pad_xy      = 32
    // Z halo per edge before MATLAB deconvblind.
    pad_z       = 20
    // Python workers used to extract/prefetch blind PSF chunks.
    blind_workers = 8
    // Parallel MATLAB deconvblind processes for chunked blind estimation.
    matlab_workers = 8
    // CPU threads per MATLAB process; code clamps to one or two.
    matlab_threads = 1
    // Per-MATLAB-call timeout in seconds; <= 0 disables the timeout.
    matlab_timeout = 1800
    // Number of Z slices used for blind PSF estimation; <= 0 uses full Z.
    blind_z_slices = 128
    // Upper bound for SNR-based PSF merge weighting to limit bright artifacts.
    snr_weight_cap = 100
    // Number of blind chunks to prefetch; <= 0 submits one worker batch at a time.
    prefetch_chunks = 0
    // Parallel CUDA deconvolution workers per process.
    decon_workers = 1
    // CUDA deconvolution XY overlap; <= 0 uses the pipeline default from PSF size.
    overlap_xy  = 0
    // Manual GPU memory budget in GB; 0/empty lets the code query available VRAM.
    vram_gb     = 0
    // Optional directory for reusable blind PSF cache entries.
    psf_cache_dir = ''
    // Disable PSF cache reads/writes even when psf_cache_dir is set.
    no_psf_cache = false
}

profiles {
    // Default Slurm/conda profile for cluster execution.
    my_cluster {
        conda.enabled = true
        conda.useMamba = true
    }

    // GPU Slurm profile that routes directly to the comparison workflow.
    compare_psf {
        conda.enabled = true
        conda.useMamba = true
        params.compare_psf = true
        params.decon_only = true
    }

    docker {
        docker.enabled = true
    }
}

process {
    // All cluster work is submitted through Slurm unless a profile overrides it.
    executor = 'slurm'

    // Deskew does not require a GPU.
    withName: DESKEW {
        cpus   = 4
        memory = '32 GB'
        queue  = 'super'
    }

    // Normal deconvolution runs on the GPU queue and builds the conda env on-node.
    withName: DECON {
        conda          = "${projectDir}/environment.yml"
        cpus           = 8
        beforeScript   = '''
            module load mamba/2.3.0

            _nxf_real_conda="$(command -v conda || true)"
            _nxf_conda_base="$PWD/.nxf-conda-shim"

            mkdir -p "$_nxf_conda_base/bin"
            printf '%s\n' \
                '_nxf_env_prefix="${1:-}"' \
                'if [ -z "$_nxf_env_prefix" ] || [ ! -d "$_nxf_env_prefix/bin" ]; then' \
                '    echo "ERROR: Nextflow conda env prefix is missing or invalid: ${_nxf_env_prefix:-<empty>}" >&2' \
                '    return 1' \
                'fi' \
                'export CONDA_PREFIX="$_nxf_env_prefix"' \
                'export CONDA_DEFAULT_ENV="$(basename "$_nxf_env_prefix")"' \
                'export PATH="$_nxf_env_prefix/bin:${PATH:-}"' \
                'export LD_LIBRARY_PATH="$_nxf_env_prefix/lib:${LD_LIBRARY_PATH:-}"' \
                'export PYTHONNOUSERSITE=1' \
                'if [ -d "$_nxf_env_prefix/etc/conda/activate.d" ]; then' \
                '    for _nxf_hook in "$_nxf_env_prefix/etc/conda/activate.d"/*.sh; do' \
                '        [ -f "$_nxf_hook" ] && . "$_nxf_hook"' \
                '    done' \
                '    unset _nxf_hook' \
                'fi' \
                > "$_nxf_conda_base/bin/activate"

            conda() {
                if [ "${1:-}" = info ] && [ "${2:-}" = --json ]; then
                    printf '{\n  "conda_prefix": "%s"\n}\n' "$_nxf_conda_base"
                elif [ -n "$_nxf_real_conda" ]; then
                    "$_nxf_real_conda" "$@"
                else
                    echo "ERROR: conda command is not available" >&2
                    return 127
                fi
            }
        '''
        queue          = 'GPUp40'          // Slurm partition/queue for GPU work.
        clusterOptions = '--gres=gpu:1' // Request one GPU from Slurm.
        cpus           = 8              // CPU cores reserved for Python/MATLAB helpers.
        memory         = '32 GB'        // RAM reserved for TIFF windows and PSF chunks.
    }

    // Comparison uses the same GPU queue because it runs CUDA deconvolution.
    withName: COMPARE_PSF {
        conda          = "${projectDir}/environment.yml"
        cpus           = 8
        beforeScript   = '''
            module load mamba/2.3.0

            _nxf_real_conda="$(command -v conda || true)"
            _nxf_conda_base="$PWD/.nxf-conda-shim"

            mkdir -p "$_nxf_conda_base/bin"
            printf '%s\n' \
                '_nxf_env_prefix="${1:-}"' \
                'if [ -z "$_nxf_env_prefix" ] || [ ! -d "$_nxf_env_prefix/bin" ]; then' \
                '    echo "ERROR: Nextflow conda env prefix is missing or invalid: ${_nxf_env_prefix:-<empty>}" >&2' \
                '    return 1' \
                'fi' \
                'export CONDA_PREFIX="$_nxf_env_prefix"' \
                'export CONDA_DEFAULT_ENV="$(basename "$_nxf_env_prefix")"' \
                'export PATH="$_nxf_env_prefix/bin:${PATH:-}"' \
                'export LD_LIBRARY_PATH="$_nxf_env_prefix/lib:${LD_LIBRARY_PATH:-}"' \
                'export PYTHONNOUSERSITE=1' \
                'if [ -d "$_nxf_env_prefix/etc/conda/activate.d" ]; then' \
                '    for _nxf_hook in "$_nxf_env_prefix/etc/conda/activate.d"/*.sh; do' \
                '        [ -f "$_nxf_hook" ] && . "$_nxf_hook"' \
                '    done' \
                '    unset _nxf_hook' \
                'fi' \
                > "$_nxf_conda_base/bin/activate"

            conda() {
                if [ "${1:-}" = info ] && [ "${2:-}" = --json ]; then
                    printf '{\n  "conda_prefix": "%s"\n}\n' "$_nxf_conda_base"
                elif [ -n "$_nxf_real_conda" ]; then
                    "$_nxf_real_conda" "$@"
                else
                    echo "ERROR: conda command is not available" >&2
                    return 127
                fi
            }
        '''
        queue          = 'GPU'          // Slurm partition/queue for GPU comparison runs.
        clusterOptions = '--gres=gpu:1' // Request one GPU for CUDA Richardson-Lucy.
        cpus           = 8              // CPU cores for MATLAB blind/Lucy calls and I/O.
        memory         = '32 GB'        // RAM for the larger comparison crop and outputs.
    }
}
